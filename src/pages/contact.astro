---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Azad Gharibian Dance - enrol, book us, or ask a question.">
  <section class="contact-hero section">
    <div class="container">
      <h1>Get in Touch</h1>
      <p class="contact-intro">Whether you want to join us, book us for an event, or just say hello — we would love to hear from you.</p>
    </div>
  </section>

  <section class="cards section">
    <div class="container">
      <div class="cards-grid">
        <div class="card">
          <h2>Enrol in Classes</h2>
          <p>Ready to dance? Our classes run weekly and cater to all skill levels. Ages 4 to 70+, beginners welcome.</p>
          <ul class="card-details">
            <li>All ages welcome</li>
            <li>No prior experience needed</li>
            <li>Weekly rehearsals</li>
            <li>Performance opportunities</li>
          </ul>
          <a href="https://forms.gle/xybcqQxxNzThunfX6" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Enrol Now</a>
        </div>

        <div class="card">
          <h2>Book Us for an Event</h2>
          <p>Planning a community event, wedding, or cultural celebration? AGD brings the energy of Armenian dance to your occasion.</p>
          <ul class="card-details">
            <li>Weddings and engagements</li>
            <li>Community festivals</li>
            <li>Corporate events</li>
            <li>Cultural celebrations</li>
          </ul>
          <a href="https://forms.gle/cRuzBVpuQ7gUVSv96" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Book Us</a>
        </div>
      </div>
    </div>
  </section>

  <section class="find-us section">
    <div class="container">
      <h2>Find Us</h2>
      <div class="find-us-grid">
        <div class="find-us-item">
          <h3>Email</h3>
          <a href="mailto:dance@agd.org.au">dance@agd.org.au</a>
        </div>
        <div class="find-us-item">
          <h3>Location</h3>
          <p>Unit 62/170 Forster Road<br />Mount Waverley VIC 3149</p>
        </div>
        <div class="find-us-item">
          <h3>Social</h3>
          <div class="find-us-social">
            <a href="https://www.facebook.com/AGD.melb" target="_blank" rel="noopener noreferrer" aria-label="AGD on Facebook">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/agd_melb/" target="_blank" rel="noopener noreferrer" aria-label="AGD on Instagram">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    text-align: center;
    padding-bottom: 0;
  }

  .contact-intro {
    font-size: 1.2rem;
    color: var(--color-gray-200);
    max-width: 650px;
    margin: var(--space-md) auto 0;
    line-height: 1.7;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .card {
    padding: var(--space-xl);
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    border-top: 4px solid var(--color-red);
  }

  .card h2 {
    margin-bottom: var(--space-sm);
    font-size: 1.5rem;
  }

  .card p {
    color: var(--color-gray-200);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .card-details {
    list-style: none;
    margin-bottom: var(--space-lg);
  }

  .card-details li {
    padding: var(--space-xs) 0;
    color: var(--color-gray-200);
    padding-left: 1.5rem;
    position: relative;
  }

  .card-details li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-red);
    font-weight: 700;
  }

  .find-us {
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: var(--space-xl);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .find-us-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .find-us-item h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
    color: var(--color-white);
  }

  .find-us-item a,
  .find-us-item p {
    color: var(--color-gray-200);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .find-us-social {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
  }

  .find-us-social a {
    opacity: 0.8;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .find-us-social a:hover {
    opacity: 1;
    transform: scale(1.1);
  }
</style>
