---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Azad Gharibian Dance - enrol, book us, or ask a question.">
  <section class="contact-hero section">
    <div class="container">
      <h1>Get in Touch</h1>
      <p class="contact-intro">Whether you want to join us, book us for an event, or just say hello — we would love to hear from you.</p>
    </div>
  </section>

  <section class="cards section">
    <div class="container">
      <div class="cards-grid">
        <div class="card">
          <h2>Enrol in Classes</h2>
          <p>Ready to dance? Our classes run weekly and cater to all skill levels. Ages 4 to 70+, beginners welcome.</p>
          <ul class="card-details">
            <li>All ages welcome</li>
            <li>No prior experience needed</li>
            <li>Weekly rehearsals</li>
            <li>Performance opportunities</li>
          </ul>
          <a href="https://forms.gle/xybcqQxxNzThunfX6" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Enrol Now</a>
        </div>

        <div class="card">
          <h2>Book Us for an Event</h2>
          <p>Planning a community event, wedding, or cultural celebration? AGD brings the energy of Armenian dance to your occasion.</p>
          <ul class="card-details">
            <li>Weddings and engagements</li>
            <li>Community festivals</li>
            <li>Corporate events</li>
            <li>Cultural celebrations</li>
          </ul>
          <a href="https://forms.gle/cRuzBVpuQ7gUVSv96" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Book Us</a>
        </div>
      </div>
    </div>
  </section>

  <section class="find-us section">
    <div class="container">
      <h2>Find Us</h2>
      <div class="find-us-grid">
        <div class="find-us-item">
          <h3>Email</h3>
          <a href="mailto:dance@agd.org.au">dance@agd.org.au</a>
        </div>
        <div class="find-us-item">
          <h3>Location</h3>
          <p>Unit 62/170 Forster Road<br />Mount Waverley VIC 3149</p>
        </div>
        <div class="find-us-item">
          <h3>Social</h3>
          <div class="find-us-social">
            <a href="https://www.facebook.com/AGD.melb" target="_blank" rel="noopener noreferrer">Facebook</a>
            <a href="https://www.instagram.com/agd_melb/" target="_blank" rel="noopener noreferrer">Instagram</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    text-align: center;
    padding-bottom: 0;
  }

  .contact-intro {
    font-size: 1.2rem;
    color: var(--color-gray-200);
    max-width: 650px;
    margin: var(--space-md) auto 0;
    line-height: 1.7;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .card {
    padding: var(--space-xl);
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    border-top: 4px solid var(--color-red);
  }

  .card h2 {
    margin-bottom: var(--space-sm);
    font-size: 1.5rem;
  }

  .card p {
    color: var(--color-gray-200);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .card-details {
    list-style: none;
    margin-bottom: var(--space-lg);
  }

  .card-details li {
    padding: var(--space-xs) 0;
    color: var(--color-gray-200);
    padding-left: 1.5rem;
    position: relative;
  }

  .card-details li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-red);
    font-weight: 700;
  }

  .find-us {
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: var(--space-xl);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .find-us-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .find-us-item h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
    color: var(--color-white);
  }

  .find-us-item a,
  .find-us-item p {
    color: var(--color-gray-200);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .find-us-social {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
  }
</style>
