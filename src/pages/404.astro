---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you are looking for does not exist.">
  <section class="not-found">
    <div class="container">
      <h1>404</h1>
      <p class="not-found-message">This page does not exist. Maybe you were looking for one of these?</p>
      <nav class="not-found-links" aria-label="Helpful links">
        <a href="/" class="btn btn-primary">Go Home</a>
        <a href="/about" class="btn btn-secondary">About Us</a>
        <a href="/join" class="btn btn-secondary">Join Us</a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .not-found h1 {
    font-size: 6rem;
    color: rgba(255, 255, 255, 0.2);
    margin-bottom: var(--space-sm);
  }

  .not-found-message {
    font-size: 1.2rem;
    color: var(--color-gray-200);
    margin-bottom: var(--space-xl);
  }

  .not-found-links {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
